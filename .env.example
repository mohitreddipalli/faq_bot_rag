# Example environment variables for FAQ Bot
# Copy this file to .env and fill in your keys locally.

# LLM API key
GROQ_API_KEY=

# Optional model override for Groq chat completions
GROQ_MODEL=llama-3.1-8b-instant

# RAG configuration
SIMILARITY_THRESHOLD=0.25
TOP_K=3
CHUNK_SIZE=180
CHUNK_OVERLAP=30
