# Example environment variables for FAQ Bot
# Copy this file to .env and fill in your keys locally.

# LLM API keys
GEMINI_API_KEY=
OPENAI_API_KEY=

# GROQ / Sanity API key (paste your GROQ key here locally; do NOT commit .env)
GROQ_API_KEY=

# RAG configuration
SIMILARITY_THRESHOLD=0.25
TOP_K=3
CHUNK_SIZE=250
CHUNK_OVERLAP=50
